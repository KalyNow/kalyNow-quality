# Application URLs
BASE_URL=http://kalynow.mg
WEB_URL=http://localhost:3000

# Browser for Selenium tests (chrome, firefox, edge)
BROWSER=chrome

# Appium settings for mobile tests
APPIUM_URL=http://localhost:4723/wd/hub
PLATFORM_NAME=Android
DEVICE_NAME=emulator-5554
APP_PATH=/path/to/your/app.apk

# Test user credentials (used by load tests and e2e tests)
# Must be an existing and verified account for /api/us/auth/login.
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!

# Locust settings
LOCUST_USERS=154
LOCUST_SPAWN_RATE=3
LOCUST_RUN_TIME=60s
